<UserControl x:Class="RestaurantComenzi.UI.Views.CartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#F4F6F8">

	<Grid Margin="30">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="2*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0" Margin="0,0,10,0">
			<TextBlock Text="Coșul tău" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

			<ListBox ItemsSource="{Binding Items}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Border Background="White"
                                CornerRadius="10"
                                Margin="0,0,0,10"
                                Padding="15">
							<Border.Effect>
								<DropShadowEffect BlurRadius="10" Color="#EEEEEE" ShadowDepth="2" Opacity="0.5"/>
							</Border.Effect>

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="100"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<StackPanel Grid.Column="0">
									<TextBlock Text="{Binding Produs.Denumire}" FontWeight="SemiBold" FontSize="16"/>
									<TextBlock Text="{Binding Produs.TipProdus}" Foreground="Gray" FontSize="12"/>
								</StackPanel>

								<TextBlock Grid.Column="1"
                                           Text="{Binding Cantitate, StringFormat='x{0}'}"
                                           VerticalAlignment="Center"
                                           Margin="20,0"
                                           FontWeight="Bold"/>

								<TextBlock Grid.Column="2"
                                           Text="{Binding Produs.Pret, StringFormat='{}{0} lei'}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontSize="16"/>

								<Button Grid.Column="3"
                                        Content="✕"
                                        Command="{Binding DataContext.StergeProdusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="Red"
                                        FontWeight="Bold"
                                        Margin="15,0,0,0"
                                        Cursor="Hand"/>
							</Grid>
						</Border>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<TextBlock Text="{Binding MesajComanda}"
                       Foreground="#007ACC"
                       Margin="0,10"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       FontStyle="Italic"/>
		</StackPanel>

		<Border Grid.Column="1"
                Background="White"
                CornerRadius="15"
                Padding="25"
                Margin="20,45,0,0"
                VerticalAlignment="Top">
			<Border.Effect>
				<DropShadowEffect BlurRadius="15" Color="#DDDDDD" ShadowDepth="3" Opacity="0.4"/>
			</Border.Effect>

			<StackPanel>
				<TextBlock Text="Sumar Comandă"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           Foreground="#333"/>

				<Grid Margin="0,0,0,10">
					<TextBlock Text="Subtotal" FontSize="16" Foreground="Gray"/>
					<TextBlock Text="{Binding TotalBrut, StringFormat='{}{0} lei'}" FontSize="16" HorizontalAlignment="Right"/>
				</Grid>

				<Grid Margin="0,0,0,10">
					<TextBlock Text="Discount" FontSize="16" Foreground="Gray"/>
					<TextBlock Text="{Binding Discount, StringFormat='-{0} lei'}" FontSize="16" Foreground="Green" HorizontalAlignment="Right"/>
				</Grid>

				<Grid Margin="0,0,0,10">
					<TextBlock Text="Transport" FontSize="16" Foreground="Gray"/>
					<TextBlock Text="{Binding CostTransport, StringFormat='{}{0} lei'}" FontSize="16" HorizontalAlignment="Right"/>
				</Grid>

				<Separator Margin="0,15" Background="#EEEEEE"/>

				<Grid Margin="0,0,0,25">
					<TextBlock Text="TOTAL" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
					<TextBlock Text="{Binding TotalFinal, StringFormat='{}{0} lei'}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#E85D04"
                               HorizontalAlignment="Right"/>
				</Grid>

				<Button Content="Plasează Comanda"
                        Height="55"
                        Background="#FF4D00"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Command="{Binding PlaseazaComandaCommand}">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="8"/>
						</Style>
					</Button.Resources>
				</Button>

				<TextBlock Text="Timp estimat: 45 min"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Foreground="Gray"
                           FontSize="12"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>