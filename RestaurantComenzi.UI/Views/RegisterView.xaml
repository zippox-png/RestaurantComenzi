<UserControl x:Class="RestaurantComenzi.UI.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">

	<Grid Background="#F4F6F8">
		<Border Width="450"
                Padding="35"
                Background="White"
                CornerRadius="15"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

			<Border.Effect>
				<DropShadowEffect BlurRadius="20" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5"/>
			</Border.Effect>

			<StackPanel>
				<TextBlock Text="Creare Cont"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#333"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>

				<TextBlock Text="Nume" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<TextBox Text="{Binding Nume, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5,0"/>

				<TextBlock Text="Prenume" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<TextBox Text="{Binding Prenume, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5,0"/>

				<TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5,0"/>

				<TextBlock Text="Parolă" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<PasswordBox x:Name="RegPassBox" Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5,0"/>

				<TextBlock Text="Telefon" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<TextBox Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="5,0"/>

				<TextBlock Text="Adresă livrare" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<TextBox Text="{Binding Adresa, UpdateSourceTrigger=PropertyChanged}"
                         Height="70"
                         Margin="0,0,0,20"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Padding="5"/>

				<Button Content="Înregistrare"
                        Height="45"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        Command="{Binding RegisterCommand}"
                        Margin="0,0,0,10">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="5"/>
						</Style>
					</Button.Resources>
				</Button>

				<Button Content="Anulează"
                        Height="45"
                        Background="#9E9E9E"
                        Foreground="White"
                        Cursor="Hand"
                        Command="{Binding CancelCommand}">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="5"/>
						</Style>
					</Button.Resources>
				</Button>

				<TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           Margin="0,15,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>