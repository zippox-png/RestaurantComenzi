<UserControl x:Class="RestaurantComenzi.UI.Views.ClientDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantComenzi.UI.Views">
    <Grid Margin="10">
        <DataGrid ItemsSource="{Binding ComenziClient}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding DataComanda, StringFormat=dd/MM/yyyy HH:mm}"/>
                <DataGridTextColumn Header="Cod" Binding="{Binding CodComanda}"/>
                <DataGridTextColumn Header="Total" Binding="{Binding PretTotal}"/>
                <DataGridTextColumn Header="Stare" Binding="{Binding Stare}"/>
                <DataGridTemplateColumn Header="Acțiuni">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Anulează" 
                                    Command="{Binding DataContext.AnuleazaComandaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>