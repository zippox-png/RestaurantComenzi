<UserControl x:Class="RestaurantComenzi.UI.Views.EmployeeDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl>
        <TabItem Header="Comenzi Active">
            <DataGrid ItemsSource="{Binding ComenziActive}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Client ID" Binding="{Binding UtilizatorId}"/>
                    <DataGridTextColumn Header="Stare" Binding="{Binding Stare}"/>
                    <DataGridTemplateColumn Header="Update">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Pasul Următor" Command="{Binding DataContext.MutaStareComandaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
        <TabItem Header="Stocuri Critice">
            <ListView ItemsSource="{Binding PreparatePeTerminate}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Produs" DisplayMemberBinding="{Binding Denumire}"/>
                        <GridViewColumn Header="Stoc Rămas" DisplayMemberBinding="{Binding CantitateTotala}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </TabItem>
    </TabControl>
</UserControl>