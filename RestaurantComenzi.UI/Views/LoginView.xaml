<UserControl x:Class="RestaurantComenzi.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vms="clr-namespace:RestaurantComenzi.UI.ViewModels"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="600" d:DesignWidth="800">

	<Grid Background="#F4F6F8">
		<Border Width="400"
                Padding="35"
                Background="White"
                CornerRadius="15"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

			<Border.Effect>
				<DropShadowEffect BlurRadius="20" Color="#CCCCCC" ShadowDepth="2" Opacity="0.5"/>
			</Border.Effect>

			<StackPanel>
				<TextBlock Text="Autentificare"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

				<TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Height="35"
                         Margin="0,0,0,15"
                         VerticalContentAlignment="Center"
                         Padding="10,0"/>

				<TextBlock Text="Parolă" FontWeight="SemiBold" Margin="0,0,0,5"/>
				<PasswordBox x:Name="PassBox"
                             Height="35"
                             Margin="0,0,0,20"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>

				<Button Content="Login"
                        Height="45"
                        Background="#007ACC"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,10">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="5"/>
						</Style>
					</Button.Resources>
				</Button>

				<Button Content="Creează cont nou"
                        Background="Transparent"
                        Foreground="#E85D04"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Command="{Binding GoToRegisterCommand}"/>

				<TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           Margin="0,15,0,0"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>